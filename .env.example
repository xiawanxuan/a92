# FastAPI
APP_NAME=Sonar Classification System
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sonar_db

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=sonar-images

# Redis
REDIS_URL=redis://localhost:6379/0

# PyTorch
MODEL_PATH=./backend/models/resnet50_sonar.pth
DEVICE=cpu
BATCH_SIZE=16
TILE_SIZE=512

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
